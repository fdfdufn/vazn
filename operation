<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Blue Site</title>

<style>

*{
box-sizing:border-box;
margin:0;
padding:0;
font-family:system-ui, -apple-system, Arial;
}

body{
background:linear-gradient(160deg,#07142b,#0a2f6b);
color:white;
min-height:100vh;
overflow-x:hidden;
}

/* glow cursor */

.cursor-glow{
position:fixed;
width:300px;
height:300px;
border-radius:50%;
background:radial-gradient(circle,rgba(80,140,255,0.25),transparent 65%);
pointer-events:none;
transform:translate(-50%,-50%);
transition:opacity .2s;
z-index:9999;
}

/* header */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 30px;
}

.home-btn{
background:rgba(40,120,255,0.9);
border:none;
padding:10px 20px;
border-radius:10px;
color:white;
font-size:15px;
cursor:pointer;
transition:.25s;
}

.home-btn:hover{
transform:translateY(-2px);
box-shadow:0 10px 20px rgba(60,120,255,.4);
background:#3b82ff;
}

/* main container */

.container{
max-width:900px;
margin:auto;
padding:20px;
}

/* title */

h1{
font-size:2.6em;
margin-bottom:10px;
}

/* description */

.description{
color:#c7d7ff;
line-height:1.6;
margin-bottom:35px;
}

/* FAQ card */

.faq{
display:flex;
flex-direction:column;
gap:14px;
}

.faq-item{
background:rgba(15,40,95,.6);
border-radius:14px;
backdrop-filter:blur(10px);
overflow:hidden;
transition:.25s;
}

.faq-item:hover{
transform:translateY(-3px);
box-shadow:0 10px 25px rgba(40,90,255,.25);
}

/* question button */

.question{
width:100%;
padding:18px;
font-size:16px;
text-align:left;
background:none;
border:none;
color:white;
cursor:pointer;
display:flex;
justify-content:space-between;
align-items:center;
}

/* animated arrow */

.arrow{
transition:transform .35s;
}

.faq-item.active .arrow{
transform:rotate(180deg);
}

/* answer */

.answer{
max-height:0;
overflow:hidden;
transition:max-height .45s ease;
padding:0 18px;
}

.answer p{
padding-bottom:18px;
color:#d3ddff;
}

/* mobile */

@media (max-width:700px){

header{
padding:15px 18px;
}

h1{
font-size:2em;
}

.container{
padding:15px;
}

.question{
font-size:17px;
padding:20px;
}

.faq-item{
border-radius:18px;
}

}

</style>
</head>

<body>

<div class="cursor-glow" id="glow"></div>

<header>
<div></div>
<button class="home-btn">Home</button>
</header>

<div class="container">

<h1>edit here</h1>

<p class="description">
Edit this description text here. This section introduces your website and
gives users context before they open the questions below.
</p>

<div class="faq">

<div class="faq-item">
<button class="question">Question 1 <span class="arrow">▼</span></button>
<div class="answer"><p>Edit the answer text for question 1.</p></div>
</div>

<div class="faq-item">
<button class="question">Question 2 <span class="arrow">▼</span></button>
<div class="answer"><p>Edit the answer text for question 2.</p></div>
</div>

<div class="faq-item">
<button class="question">Question 3 <span class="arrow">▼</span></button>
<div class="answer"><p>Edit the answer text for question 3.</p></div>
</div>

<div class="faq-item">
<button class="question">Question 4 <span class="arrow">▼</span></button>
<div class="answer"><p>Edit the answer text for question 4.</p></div>
</div>

<div class="faq-item">
<button class="question">Question 5 <span class="arrow">▼</span></button>
<div class="answer"><p>Edit the answer text for question 5.</p></div>
</div>

</div>

</div>

<script>

/* FAQ smooth toggle */

document.querySelectorAll(".question").forEach(btn=>{
btn.addEventListener("click",()=>{

const item = btn.parentElement;
const answer = btn.nextElementSibling;

item.classList.toggle("active");

if(answer.style.maxHeight){
answer.style.maxHeight=null;
}else{
answer.style.maxHeight=answer.scrollHeight+"px";
}

});
});

/* mouse glow */

const glow=document.getElementById("glow");

document.addEventListener("mousemove",e=>{
glow.style.left=e.clientX+"px";
glow.style.top=e.clientY+"px";
});

/* hide glow on mobile */

if(window.innerWidth<700){
glow.style.display="none";
}

</script>

</body>
</html>